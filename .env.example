# Database (Supabase PostgreSQL) — set in Vercel env, never commit real values
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Auth.js / NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Admin bootstrap (used only by `npm run db:seed` — never commit real values)
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="choose-a-strong-password"

# @mention note emails (optional — Owner.email on Owners page is preferred)
# Tagging @waqas / @naseeb in a note emails these addresses when mail is configured.
MENTION_EMAIL_WAQAS="waqas@example.com"
MENTION_EMAIL_NASEEB="naseeb@example.com"

# Free email — pick ONE provider
# A) Resend (https://resend.com — free tier). Without a domain, use onboarding@resend.dev
#    and you can only send to your Resend account email until a domain is verified.
RESEND_API_KEY=""
EMAIL_FROM="Hostora <onboarding@resend.dev>"

# B) SMTP (e.g. Gmail App Password — free)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="you@gmail.com"
# SMTP_PASS="your-app-password"
# EMAIL_FROM="Hostora <you@gmail.com>"

# Supabase Storage (optional — receipts & documents)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
