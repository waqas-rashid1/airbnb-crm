generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BookingPlatform {
  AIRBNB
  BOOKING_COM
  DIRECT
  OTHER
}

enum BookingStatus {
  UPCOMING
  CHECKED_IN
  COMPLETED
  CANCELLED
}

enum ExpenseCategory {
  RENT
  SECURITY_DEPOSIT
  ELECTRICITY
  GAS
  WATER
  INTERNET
  CLEANING
  LAUNDRY
  MAINTENANCE
  FURNITURE
  APPLIANCES
  LEGAL
  CONTRACT
  COMMISSION
  SUPPLIES
  SALARY
  MARKETING
  TAXES
  MISCELLANEOUS
}

enum ReimbursementStatus {
  PENDING
  PARTIAL
  REIMBURSED
  NOT_NEEDED
}

enum OwnerTransactionType {
  INVESTMENT
  WITHDRAWAL
  PROFIT_DISTRIBUTION
}

enum DocumentType {
  PROPERTY
  EXPENSE_RECEIPT
  LEASE
  OTHER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Property {
  id               String    @id @default(cuid())
  name             String
  buildingName     String?
  roomNumber       String?
  floor            String?
  city             String?
  address          String
  unitType         String?
  monthlyRent      Decimal   @db.Decimal(12, 2)
  securityDeposit  Decimal   @db.Decimal(12, 2)
  dealerCommission Decimal   @db.Decimal(12, 2) @default(0)
  stampPaper       Decimal   @db.Decimal(12, 2) @default(0)
  leaseStart       DateTime?
  leaseEnd         DateTime?
  landlordName     String?
  landlordPhone    String?
  landlordEmail    String?
  landlordNotes    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  bookings  Booking[]
  expenses  Expense[]
  assets    Asset[]
  documents Document[]
  owners    Owner[]

  @@map("properties")
}

model Booking {
  id           String          @id @default(cuid())
  bookingCode  String          @unique
  propertyId   String
  guestName    String
  phone        String?
  platform     BookingPlatform @default(AIRBNB)
  checkInDate  DateTime
  checkInTime  String          @default("15:00")
  checkOutDate DateTime
  checkOutTime String          @default("11:00")
  nights       Int
  guestsCount  Int             @default(1)
  revenue      Decimal         @db.Decimal(12, 2)
  cleaningFee  Decimal         @db.Decimal(12, 2) @default(0)
  platformFee  Decimal         @db.Decimal(12, 2) @default(0)
  discount     Decimal         @db.Decimal(12, 2) @default(0)
  extraCharges Decimal         @db.Decimal(12, 2) @default(0)
  netRevenue   Decimal         @db.Decimal(12, 2)
  status       BookingStatus   @default(UPCOMING)
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([checkInDate])
  @@index([checkOutDate])
  @@index([status])
  @@map("bookings")
}

model Expense {
  id                  String              @id @default(cuid())
  propertyId          String
  date                DateTime
  category            ExpenseCategory
  description         String
  paidBy              String?
  amount              Decimal             @db.Decimal(12, 2)
  receiptUrl          String?
  isRecurring         Boolean             @default(false)
  isRefundable        Boolean             @default(false)
  reimbursementStatus ReimbursementStatus @default(PENDING)
  reimbursedAmount    Decimal             @db.Decimal(12, 2) @default(0)
  monthlyNote         String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  property       Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reimbursements Reimbursement[]

  @@index([propertyId])
  @@index([date])
  @@index([category])
  @@index([paidBy])
  @@index([reimbursementStatus])
  @@map("expenses")
}

model Reimbursement {
  id        String   @id @default(cuid())
  expenseId String
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime @default(now())
  paidTo    String
  paidFrom  String?
  notes     String?
  createdAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
  @@index([date])
  @@index([paidTo])
  @@map("reimbursements")
}

model Owner {
  id         String   @id @default(cuid())
  propertyId String
  name       String
  email      String?
  phone      String?
  investment Decimal  @db.Decimal(12, 2) @default(0)
  withdrawal Decimal  @db.Decimal(12, 2) @default(0)
  profitDist Decimal  @db.Decimal(12, 2) @default(0)
  balance    Decimal  @db.Decimal(12, 2) @default(0)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property     Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  transactions OwnerTransaction[]

  @@index([propertyId])
  @@map("owners")
}

model OwnerTransaction {
  id           String               @id @default(cuid())
  ownerId      String
  type         OwnerTransactionType
  amount       Decimal              @db.Decimal(12, 2)
  date         DateTime             @default(now())
  description  String?
  balanceAfter Decimal              @db.Decimal(12, 2)
  createdAt    DateTime             @default(now())

  owner Owner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([date])
  @@map("owner_transactions")
}

model Asset {
  id           String    @id @default(cuid())
  propertyId   String
  name         String
  purchaseDate DateTime?
  cost         Decimal   @db.Decimal(12, 2)
  currentValue Decimal   @db.Decimal(12, 2)
  isRefundable Boolean   @default(false)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("assets")
}

model Document {
  id         String       @id @default(cuid())
  propertyId String?
  name       String
  type       DocumentType @default(OTHER)
  url        String
  size       Int?
  mimeType   String?
  createdAt  DateTime     @default(now())

  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@map("documents")
}

model Report {
  id        String   @id @default(cuid())
  name      String
  type      String
  period    String?
  data      Json
  createdAt DateTime @default(now())

  @@map("reports")
}

model Settings {
  id                  String   @id @default(cuid())
  currency            String   @default("PKR")
  currencySymbol      String   @default("Rs")
  defaultCheckInTime  String   @default("15:00")
  defaultCheckOutTime String   @default("11:00")
  expenseCategories   Json?
  bookingPlatforms    Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("settings")
}
